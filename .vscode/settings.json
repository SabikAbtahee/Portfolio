    "vssolution.openSolutions.inRootFolder": false,
    "terminal.integrated.tabs.defaultColor": "terminal.ansiGreen",
    "gitflow.views.feature.showRemoteBranches": true,
    "bracketPairColorizer.depreciation-notice": false,
