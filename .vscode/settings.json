        {
            "name": "Toggle Bookmarks",
            "icon": {
                "dark": "builtin/bookmark_dark.svg",
                "light": "builtin/"
            },
            "command": "git.commit"
        },
        {
            "name": "Toggle Bookmarks x",
            "icon": {
                "dark": "builtin/bookmark_dark.svg",
                "light": "builtin/"
            },
            "command": "git.push"
        }
    ],
    "ShortcutMenuBar.openFilesList": false,
    "vssolution.altSolutionFolders": [],
