    "stylelint.validate": ["css", "scss"],
    "editor.formatOnType": true,
    "editor.stickyScroll.enabled": false,
    "notebook.stickyScroll.enabled": true,
    "workbench.tree.enableStickyScroll": false,
    "git.enableSmartCommit": true,
    "editor.lineHeight": 24,
    "gitlens.launchpad.indicator.enabled": false,
    "window.title": "${dirty}${rootName}",
    "workbench.iconTheme": "flow-deep",
    "git.replaceTagsWhenPull": true,

    "github.copilot.advanced": {
        "authProvider": "github"
    },
    "scm-buttons.showGitStash": true,
    "diffEditor.ignoreTrimWhitespace": true,
    "javascript.preferences.importModuleSpecifier": "shortest",
    "typescript.preferences.importModuleSpecifier": "shortest",
    "editor.wordWrap": "on",
    "gitlens.views.scm.grouped.views": {
        "commits": false,
        "branches": false,
        "remotes": false,
        "stashes": false,
        "tags": false,
        "worktrees": false,
        "contributors": false,
        "repositories": false,
        "searchAndCompare": false,
        "launchpad": false
    },
    "testExplorer.showOnRun": true,
    "typescript.suggest.autoImports": true,
    "javascript.suggest.autoImports": true,
    "terminal-keeper.active": "default",
    "terminal-keeper.activateOnStartup": false,
    "terminal-keeper.theme": "chaos",
    "terminal-keeper.killProcess": true,
    "actionButtons": {
        "commands": [
            {
                "name": "$(notebook-execute)",
                "singleInstance": false,
                "command": "npm run start:dev",
                "terminalName": "$(notebook-execute) serve",
                "ignoreClear": true
            },
            {
                "name": "$(archive)",
                "singleInstance": false,
                "command": "npm run build",
                "terminalName": "$(archive) build",
                "ignoreClear": true
            },
            {
                "name": "$(extensions-install-count)",
                "singleInstance": false,
                "command": "npm install",
                "terminalName": "$(extensions-install-count) install",
                "ignoreClear": true
            },
            {
                "name": "$(test-view-icon)",
                "singleInstance": false,
                "command": "npm run test",
                "terminalName": "$(test-view-icon) test",
                "ignoreClear": true
            },
            {
                "name": "$(extensions-rating)",
                "singleInstance": false,
                "command": "npm run prettier && npm run lint:fix",
                "terminalName": "$(extensions-rating) cwd",
                "ignoreClear": true
            }
        ],
        "defaultColor": "none",
        "reloadButton": null,
        "loadNpmCommands": false
    },
    "git.blame.statusBarItem.enabled": true,
    "editor.scrollbar.verticalScrollbarSize": 2,
    "editor.scrollbar.horizontalScrollbarSize": 2,
    "bookmarks.sideBar.countBadge": "files",
    "editor.minimap.size": "fill",
    "ShortcutMenuBar.toggleTerminal": false,
    "editor.mouseWheelZoom": true,
    "terminal.integrated.mouseWheelZoom": true,
