// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
	"project_name": "AngularStarter",
	"context_servers": {},
	"terminal": {
		"dock": "bottom"
	},
	"collaboration_panel": {
		"dock": "right"
	},
	"outline_panel": {
		"dock": "right"
	},
	"buffer_font_family": ".ZedMono",
	"disable_ai": false,
	"agent": {
		"default_profile": "ask",
		"default_model": {
			"provider": "copilot_chat",
			"model": "claude-sonnet-4"
		},
		"model_parameters": [],
		"play_sound_when_agent_done": true,
		"always_allow_tool_actions": true
	},
	"double_click_in_multibuffer": "open",
	"preview_tabs": {
		"enabled": false
	},
	"tab_size": 4,
	"scroll_beyond_last_line": "vertical_scroll_margin",
	"excerpt_context_lines": 3,
	"expand_excerpt_lines": 15,
	"icon_theme": "Material Icon Theme",
	"lsp_document_colors": "inlay",
	"show_completion_documentation": true,
	"show_completions_on_input": true,
	"show_edit_predictions": true,
	"languages": {
		"HTML": {
			"language_servers": [
				"eslint",
				"tailwindcss-language-server",
				"angular",
				"typescript-language-server",
				"vscode-html-language-server",
				"!vtsls",
				"..."
			],
			"code_actions_on_format": {
				"source.fixAll.eslint": true
			}
		},
		"TypeScript": {
			"language_servers": [
				"tailwindcss-language-server",
				"angular",
				"typescript-language-server",
				"eslint",
				"!vtsls",
				"..."
			],
			"code_actions_on_format": {
				"source.addMissingImports.ts": true,
				"source.fixAll.eslint": true
			}
		},
		"TSX": {
			"language_servers": [
				"tailwindcss-language-server",
				"angular",
				"typescript-language-server",
				"!vtsls",
				"..."
			],
			"code_actions_on_format": {
				"source.addMissingImports.ts": true,
				"source.fixAll.eslint": true
			}
		},
		"JavaScript": {
			"language_servers": [
				"tailwindcss-language-server",
				"angular",
				"typescript-language-server",
				"!vtsls",
				"..."
			],
			"code_actions_on_format": {
				"source.addMissingImports.ts": true,
				"source.fixAll.eslint": true
			}
		},
		"Angular": {
			"language_servers": [
				"tailwindcss-language-server",
				"angular",
				"typescript-language-server",
				"!vtsls",
				"..."
			]
		}
	},

	"lsp": {
		"tailwindcss-language-server": {
			"initialization_options": {
				"userLanguages": {
					"html": "html",
					"typescript": "typescript"
				}
			},

			"settings": {
				"tailwindCSS": {
					"experimental": {
						"classRegex": [
							["class\\s*=\\s*[\"'`]([^\"'`]*)[\"'`]"],
							["className\\s*[:=]\\s*[\"'`]([^\"'`]*)[\"'`]"],
							["ngClass\\s*=\\s*[\"'`]([^\"'`]*)[\"'`]"]
						]
					},
					"includeLanguages": {
						"html": "html",
						"typescript": "typescript",
						"javascript": "javascript"
					},
					"validate": true,
					"emmetCompletions": true,
					"classAttributes": ["class", "className", "ngClass"],
					"lint": {
						"cssConflict": "warning",
						"invalidApply": "error",
						"invalidScreen": "error",
						"invalidVariant": "error",
						"invalidConfigPath": "error",
						"invalidTailwindDirective": "error"
					}
				}
			}
		},
		"angular": {
			"initialization_options": {
				"angular_language_server_version": "21.0.1",
				"typescript_version": "5.9.3"
			}
		},
		"eslint": {
			"settings": {
				"eslint.useFlatConfig": true,
				"eslint.options": {
					"overrideConfigFile": "./eslint.config.mjs"
				},
				"eslint.validate": [
					"javascript",
					"typescript",
					{ "language": "html", "autoFix": true }
				],
				"eslint.probe": ["javascript", "typescript", "html"],
				"eslint.codeActionOnSave.rules": ["@angular-eslint/*"],
				"eslint.problems.shortenToSingleLine": true
			}
		}
	},
	"inlay_hints": {
		"show_background": true,
		"enabled": false,
		"show_other_hints": true,
		"show_parameter_hints": true,
		"show_type_hints": true,
		"show_value_hints": true
	},
	"debugger": {
		"dock": "left"
	},
	"git_panel": {
		"dock": "left",
		"default_width": 300
	},
	"project_panel": {
		"dock": "left",
		"default_width": 300,
		"sticky_scroll": false,
		"show_diagnostics": "errors",
		"entry_spacing": "standard",
		"button": true,
		"auto_fold_dirs": false,
		"git_status": true,
		"file_icons": true,
		"folder_icons": true
	},
	"tabs": {
		"file_icons": true,
		"git_status": true,
		"show_diagnostics": "errors",
		"show_close_button": "always"
	},

	"title_bar": {
		"show_menus": true,
		"show_sign_in": true,
		"show_branch_icon": true,
		"show_branch_name": true,
		"show_project_items": true,
		"show_onboarding_banner": true,
		"show_user_picture": true
	},
	"base_keymap": "VSCode",
	"ui_font_size": 16,
	"buffer_font_size": 16.0,
	"theme": {
		"mode": "system",
		"light": "One Light",
		"dark": "One Light"
	},
	"minimap": {
		"show": "auto",
		"thumb": "always",
		"thumb_border": "none",
		"current_line_highlight": "line"
	},
	"tab_bar": {
		"show": true,
		"show_nav_history_buttons": false,
		"show_tab_bar_buttons": true
	},
	"status_bar": {
		"active_language_button": true,
		"cursor_position_button": true,
		"line_endings_button": true
	},
	"features": {
		"edit_prediction_provider": "none"
	},
	"git": {
		"inline_blame": {
			"show_commit_summary": true
		},
		"branch_picker": {
			"show_author_name": true
		}
	}
}
